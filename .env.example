# Copy to .env.local and fill in values. Validated at runtime by src/env.ts.

# Required: contact form emails
RESEND_API_KEY=

# Required: emoji reactions API + Drizzle scripts
DATABASE_URL=

# Required: music storage/signing (server-only — no NEXT_PUBLIC_ prefix)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=

# Optional: CloudFront signed URLs (falls back to S3 pre-signed URLs if absent)
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=

# Optional analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS=
NEXT_PUBLIC_CLARITY_APP_CODE=

# Optional Sentry source-map upload in CI
SENTRY_AUTH_TOKEN=

# Optional: skip server env validation (for Docker build stages)
# SKIP_ENV_VALIDATION=true

# Optional terminal resume overrides
TERMINAL_SSH_HOST_KEY=
TERMINAL_SSH_PORT=
TERMINAL_SSH_HOST=
TERMINAL_HTTP_PORT=
TERMINAL_HTTP_HOST=
TERMINAL_CHALK_LEVEL=
